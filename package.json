{
  "name": "upstack",
  "version": "0.1.0",
  "description": "upstack — a progressive React learning platform (Next.js App Router + MDX + Sandpack).",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prepare:modern-monaco": "node scripts/prepare-modern-monaco-assets.mjs",
    "predev": "npm run prepare:modern-monaco",
    "dev": "next dev",
    "prebuild": "npm run prepare:modern-monaco",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:solutions": "tsx scripts/verify-solutions.ts",
    "verify:concept-map": "tsx scripts/verify-concept-map.ts",
    "verify:smoke": "tsx scripts/smoke-assessment.ts",
    "e2e": "node drive.e2e.mjs",
    "ci:content": "npm run verify:concept-map && npm run verify:solutions"
  },
  "dependencies": {
    "@babel/parser": "7.29.7",
    "@codesandbox/sandpack-react": "2.20.0",
    "@monaco-editor/react": "^4.7.0",
    "gray-matter": "^4.0.3",
    "mermaid": "^11.16.0",
    "modern-monaco": "0.4.2",
    "monaco-editor": "^0.55.1",
    "next": "^15.1.6",
    "next-mdx-remote": "^5.0.0",
    "prettier": "^3.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^2.1.9",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@gsap/react": "^2.1.2",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15.1.6",
    "@svgr/webpack": "^8.1.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fast-glob": "^3.3.3",
    "gsap": "^3.15.0",
    "jsdom": "^25.0.1",
    "motion": "^12.42.2",
    "playwright": "^1.61.1",
    "tsx": "^4.19.2",
    "typescript": "6.0.3",
    "vitest": "^2.1.8"
  }
}
